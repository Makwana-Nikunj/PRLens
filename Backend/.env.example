# ============================================
# PRLens Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Server Configuration
# ============================================
PORT=8000
NODE_ENV=development

# ============================================
# Database
# ============================================
# PostgreSQL connection string with pgvector extension
DATABASE_URL=postgresql://user:password@localhost:5432/prlens?sslmode=require

# Optional: Database connection pool size (default: 10)
DB_POOL_SIZE=10

# ============================================
# AI Service Configuration
# ============================================
# Base URL for AI API (OpenAI, OpenRouter, etc.)
AI_BASE_URL=https://openrouter.ai/api/v1

# API key for AI service
AI_API_KEY=your-ai-api-key-here

# AI model to use for PR analysis
AI_MODEL=your-model-name

# Secondary model for fallback (optional)
SECONDARY_AI_MODEL=gpt-3.5-turbo

# Multiple provider API keys for fallback (optional)
PROVIDER_2_API_KEY=
PROVIDER_3_API_KEY=
PROVIDER_4_API_KEY=
PROVIDER_5_API_KEY=

# Embedding model for RAG
EMBEDDING_MODEL=gemini-embedding-001

# ============================================
# Embeddings Service (RAG)
# ============================================
# Gemini API key for embeddings (required)
GEMINI_API_KEY=your-gemini-api-key-here

# Enable/disable RAG system (default: true)
RAG_ENABLED=true

# Number of similar chunks to retrieve (default: 5)
RAG_TOP_K=5

# Minimum similarity threshold for retrieval (0.0-1.0, default: 0.75)
RAG_SIMILARITY_THRESHOLD=0.75

# ============================================
# JWT Authentication
# ============================================
# Secret for access tokens (generate with: openssl rand -hex 32)
ACCESS_TOKEN_SECRET=your-access-token-secret-min-32-chars

# Access token expiration (default: 15m)
ACCESS_TOKEN_EXPIRY=15m

# Secret for refresh tokens (generate with: openssl rand -hex 32)
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars

# Refresh token expiration (default: 7d)
REFRESH_TOKEN_EXPIRY=7d

# Secret for summary tokens (optional, uses ACCESS_TOKEN_SECRET if not set)
JWT_SECRET=your-jwt-secret-min-32-chars

# Summary token expiration (default: 24h)
SUMMARY_TOKEN_EXPIRY=24h

# ============================================
# GitHub OAuth
# ============================================
# Create GitHub OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/auth/github/callback

# Optional: Personal GitHub token for private repo access (if not using OAuth)
GITHUB_TOKEN=

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Frontend URL for redirects
FRONTEND_URL=http://localhost:5173

# ============================================
# Token Budget Configuration (Optional)
# ============================================
# Token limits for different context sections (in tokens)
BUDGET_SYSTEM_PROMPT_TOKENS=32000
BUDGET_RAG_TOKENS=25600
BUDGET_SUMMARY_TOKENS=19200
BUDGET_USER_MESSAGE_TOKENS=6400
BUDGET_LLM_RESPONSE_TOKENS=25600

# ============================================
# Gemini Fallback Provider
# ============================================
PROVIDER_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
PROVIDER_GEMINI_API_KEY=
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ============================================
# Production Settings
# ============================================
# External URL for keep-alive pings (Render/Railway)
RENDER_EXTERNAL_URL=

# ============================================
# Example Production Values
# ============================================
# NODE_ENV=production
# PORT=8000
# DATABASE_URL=postgresql://user:pass@your-db.aws.neon.tech/prlens?sslmode=require
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-proj-xxxxx
# AI_MODEL=your-model-name
# CORS_ORIGIN=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# RENDER_EXTERNAL_URL=https://your-backend.onrender.com
